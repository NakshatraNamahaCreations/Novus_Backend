  @@index([status])
  @@index([scheduledAt])
  @@index([sentAt])
  @@index([createdById])
  @@index([type])
  @@index([audience])
  @@map("notifications")
}

model NotificationLog {
  id             Int          @id @default(autoincrement())
  notificationId Int
